rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Admin Check ─────────────────────────────────────────────────────────
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/players/$(request.auth.uid)).data.role == 'superadmin';
    }

    // ─── Players ────────────────────────────────────────────────────────────
    // Each player can read/write their own document. Superadmins can read all.
    match /players/{playerId} {
      allow read: if request.auth != null && (request.auth.uid == playerId || isSuperAdmin());
      allow write: if request.auth != null && request.auth.uid == playerId;
    }

    // ─── Drivers ────────────────────────────────────────────────────────────
    // Anyone authenticated can read any driver (needed for leaderboards later)
    // Only the owning player can create/update/delete their drivers
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.playerId == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.playerId == request.auth.uid;
    }

    // ─── Activities / Training Log ───────────────────────────────────────────
    // Players can log and read their own training activities
    match /activities/{activityId} {
      allow read: if request.auth != null
                  && resource.data.playerId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.playerId == request.auth.uid;
    }

    // ─── Discussions ─────────────────────────────────────────────────────────
    // Anyone authenticated can read. Users can only create their own messages.
    match /page_discussions/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.playerId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.playerId == request.auth.uid;
    }
  }
}
